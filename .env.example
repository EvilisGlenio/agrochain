# Generic local/script config. For local Hardhat node, use http://127.0.0.1:8545.
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xabc123...

# Sepolia config. Scripts also fall back to these when RPC_URL/PRIVATE_KEY are absent.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key
SEPOLIA_PRIVATE_KEY=0xabc123...
ETHERSCAN_API_KEY=your-key

AGRO_TOKEN=0x0000000000000000000000000000000000000000
AGRO_NFT=0x0000000000000000000000000000000000000000
AGRO_STAKING=0x0000000000000000000000000000000000000000
AGRO_DAO=0x0000000000000000000000000000000000000000

# mint-lot.ts
LOT_URI=https://example.com/metadata/lote-1.json
PRODUCT_TYPE=queijo

# stake.ts
STAKE_AMOUNT=100

# propose-set-apr.ts
NEW_APR_BPS=150000
PROPOSAL_DESCRIPTION=Set staking APR to 150000 bps

# vote.ts / execute.ts
PROPOSAL_ID=1
SUPPORT=true
